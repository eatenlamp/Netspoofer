<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="RoundedButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <!-- Use primary color by default -->
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="MaterialYouCard" parent="Widget.Material3.CardView.Elevated">
        <!-- Let the theme decide the card background based on Material 3 specs -->
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>
</resources>